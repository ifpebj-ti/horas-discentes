# Portas mapeadas para o host
PORT_MACHINE_FRONTEND=3000
PORT_MACHINE_BACKEND=5000
PORT_MACHINE_DB=5432

# Banco de dados
POSTGRES_USER=seu_usuario
POSTGRES_PASSWORD=sua_senha
POSTGRES_DB=horas_discentes_db
DATABASE_URL=Host=db;Port=5432;Database=horas_discentes_db;Username=seu_usuario;Password=sua_senha

# Frontend
# Em produção usar a URL pública da API, ex: https://api.horamais.app/api
NEXT_PUBLIC_API_URL=https://api.horamais.app/api
NEXTAUTH_SECRET=gere_com_openssl_rand_base64_32
NEXTAUTH_URL=https://horamais.app

# JWT
JWT__Key=chave_jwt_minimo_32_caracteres
JWT__Issuer=HoraMais
JWT__Audience=HoraMaisUsuarios

# Admin padrão (criado no primeiro boot)
ADMIN_EMAIL=admin@horamais.app
ADMIN_PASSWORD=SuaSenhaForteAqui

# E-mail (SMTP)
EMAIL__Remetente=seu_email@gmail.com
EMAIL__Senha=sua_senha_de_aplicativo_gmail
EMAIL__Smtp=smtp.gmail.com
EMAIL__Porta=587

# Link de convite para coordenadores
# Em produção usar a URL pública
COORDENADOR_CONVITE_LINK=https://horamais.app/criarContaCoordenador

# MinIO (armazenamento de anexos/certificados)
MINIO_ROOT_USER=usuario_minio_seguro
MINIO_ROOT_PASSWORD=senha_minio_minimo_8_chars
